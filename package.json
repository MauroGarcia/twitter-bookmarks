{
  "name": "twitter-bookmarks",
  "version": "1.0.0",
  "description": "Twitter Bookmarks Organizer - Manage your Twitter bookmarks locally",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.mjs",
    "build": "electron-vite build",
    "build:web": "vite build --config vite.web.config.mjs",
    "lint": "eslint .",
    "preview": "electron-vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "db:doctor": "electron scripts/db-tool.cjs doctor",
    "db:query": "electron scripts/db-tool.cjs query",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "seed:mock": "node tests/manual/seed-public-mock.mjs"
  },
  "build": {
    "appId": "com.pessoal.twitter-bookmarks",
    "productName": "Twitter Bookmarks",
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "twitter",
    "bookmarks",
    "organizer"
  ],
  "author": "Mauro",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.1"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.9.9",
    "lodash": "^4.18.1"
  }
}
